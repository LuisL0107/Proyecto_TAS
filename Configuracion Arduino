// ============================================================
//   ARDUINO MEGA - GPS + BMP280 + AHT20 → OLED + Serial a PC
//   Los datos se muestran en OLED y se envían por Serial (CSV)
// ============================================================

#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <TinyGPSPlus.h>
#include <Adafruit_BMP280.h>
#include <AHT20.h>

// ==================== CONFIGURACIÓN ====================
#define SCREEN_WIDTH  128
#define SCREEN_HEIGHT 64
#define OLED_ADDRESS  0x3C

// GPS UART3: RX = D15, TX = D14
#define GPS_RX_PIN    15
#define GPS_TX_PIN    14

// I2C: SDA = D20, SCL = D21
#define I2C_SDA       20
#define I2C_SCL       21

// ==================== OBJETOS ====================
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);
TinyGPSPlus gps;
Adafruit_BMP280 bmp;
AHT20 aht20;

// ==================== VARIABLES ====================
// GPS
double lat = 0, lng = 0;
float altitud = 0, velocidad = 0;
int satelites = 0;

// BMP280
float temp_bmp = 0, presion = 0;

// AHT20
float temp_aht = 0, humedad = 0;

// Control
unsigned long ultimoEnvio = 0;
unsigned long ultimoOLED = 0;
bool oledOK = false;
bool bmpOK = false;
bool ahtOK = false;
unsigned long contador = 0;

// ==================== SETUP ====================
void setup() {
  Serial.begin(115200);
  delay(1000);
  
  Serial.println("========================================");
  Serial.println("   ARDUINO MEGA - LOGGER + OLED");
  Serial.println("========================================");
  
  // ===== I2C =====
  Wire.begin();
  Wire.setClock(100000);
  Serial.println("[I2C] OK");
  
  // ===== ESCANEAR I2C =====
  scanI2C();
  
  // ===== OLED =====
  Serial.println("[OLED] Inicializando...");
  if(!display.begin(SSD1306_SWITCHCAPVCC, OLED_ADDRESS)) {
    Serial.println("[OLED] ERROR");
    oledOK = false;
  } else {
    oledOK = true;
    Serial.println("[OLED] OK");
    display.clearDisplay();
    display.setTextSize(1);
    display.setTextColor(SSD1306_WHITE);
    display.setCursor(0, 0);
    display.println("MEGA LOGGER");
    display.println("===========");
    display.println("Iniciando...");
    display.display();
  }
  
  // ===== BMP280 =====
  if(!bmp.begin(0x76)) {
    if(!bmp.begin(0x77)) {
      Serial.println("[BMP280] ERROR");
      bmpOK = false;
    } else {
      bmpOK = true;
      Serial.println("[BMP280] OK (0x77)");
    }
  } else {
    bmpOK = true;
    Serial.println("[BMP280] OK (0x76)");
  }
  
  // ===== AHT20 =====
  if(!aht20.begin()) {
    Serial.println("[AHT20] ERROR");
    ahtOK = false;
  } else {
    ahtOK = true;
    Serial.println("[AHT20] OK");
  }
  
  // ===== GPS (UART3) =====
  Serial3.begin(9600);
  Serial.println("[GPS] OK - UART3");
  Serial.println("========================================");
  
  // Enviar cabecera CSV
  Serial.println("timestamp,lat,lng,altitud,velocidad,satelites,temp_bmp,presion,temp_aht,humedad");
  
  // Mostrar en OLED que todo está listo
  if(oledOK) {
    display.clearDisplay();
    display.setCursor(0, 0);
    display.println("MEGA LOGGER");
    display.println("===========");
    display.println("GPS: BUSCANDO");
    display.println("Sensores: OK");
    display.display();
  }
}

// ==================== ESCANEAR I2C ====================
void scanI2C() {
  Serial.println("[I2C] Escaneando dispositivos...");
  byte error, address;
  int nDevices = 0;
  
  for(address = 1; address < 127; address++) {
    Wire.beginTransmission(address);
    error = Wire.endTransmission();
    
    if(error == 0) {
      Serial.print("  - Dispositivo en 0x");
      if(address < 16) Serial.print("0");
      Serial.println(address, HEX);
      nDevices++;
    }
  }
  
  if(nDevices == 0) {
    Serial.println("  - Ningun dispositivo encontrado");
  } else {
    Serial.print("  - Total: ");
    Serial.print(nDevices);
    Serial.println(" dispositivos");
  }
}

// ==================== ACTUALIZAR OLED ====================
void actualizarOLED() {
  if(!oledOK) return;
  
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  
  // Línea 1: GPS
  display.setCursor(0, 0);
  if(gps.location.isValid()) {
    display.print("GPS:OK ");
    display.print(satelites);
    display.println(" SAT");
  } else {
    display.println("GPS:BUSCANDO");
  }
  
  // Línea 2: Temperaturas
  display.setCursor(0, 11);
  display.print("T:");
  if(temp_bmp != 0) {
    display.print(temp_bmp, 1);
    display.print("C");
  } else if(temp_aht != 0) {
    display.print(temp_aht, 1);
    display.print("C");
  } else {
    display.print("---");
  }
  
  // Línea 3: Humedad
  display.setCursor(0, 22);
  display.print("H:");
  if(humedad != 0) {
    display.print(humedad, 1);
    display.print("%");
  } else {
    display.print("---");
  }
  
  // Línea 4: Presión
  display.setCursor(0, 33);
  display.print("P:");
  if(presion != 0) {
    display.print(presion, 1);
    display.print("hPa");
  } else {
    display.print("---");
  }
  
  // Línea 5: Latitud
  display.setCursor(0, 44);
  if(gps.location.isValid()) {
    display.print("LAT:");
    display.print(lat, 4);
  } else {
    display.print("LAT:---");
  }
  
  // Línea 6: Longitud
  display.setCursor(0, 55);
  if(gps.location.isValid()) {
    display.print("LNG:");
    display.print(lng, 4);
  } else {
    display.print("LNG:---");
  }
  
  display.display();
}

// ==================== LOOP ====================
void loop() {
  // ===== LEER GPS =====
  while(Serial3.available() > 0) {
    char c = Serial3.read();
    gps.encode(c);
  }
  
  // ===== LEER SENSORES Y ENVIAR DATOS CADA 2 SEGUNDOS =====
  if(millis() - ultimoEnvio > 2000) {
    ultimoEnvio = millis();
    contador++;
    
    // Leer sensores
    if(bmpOK) {
      temp_bmp = bmp.readTemperature();
      presion = bmp.readPressure() / 100.0F;
    }
    
    if(ahtOK) {
      temp_aht = aht20.readTemperature();
      humedad = aht20.readHumidity();
    }
    
    // Obtener GPS
    if(gps.location.isValid()) {
      lat = gps.location.lat();
      lng = gps.location.lng();
    }
    if(gps.altitude.isValid()) {
      altitud = gps.altitude.meters();
    }
    if(gps.speed.isValid()) {
      velocidad = gps.speed.kmph();
    }
    satelites = gps.satellites.value();
    
    // ===== ENVIAR POR SERIAL (CSV) =====
    Serial.print(millis());
    Serial.print(",");
    Serial.print(lat, 6);
    Serial.print(",");
    Serial.print(lng, 6);
    Serial.print(",");
    Serial.print(altitud, 1);
    Serial.print(",");
    Serial.print(velocidad, 1);
    Serial.print(",");
    Serial.print(satelites);
    Serial.print(",");
    Serial.print(temp_bmp, 1);
    Serial.print(",");
    Serial.print(presion, 1);
    Serial.print(",");
    Serial.print(temp_aht, 1);
    Serial.print(",");
    Serial.println(humedad, 1);
    
    // ===== ACTUALIZAR OLED =====
    actualizarOLED();
  }
  
  delay(10);
}

  
  